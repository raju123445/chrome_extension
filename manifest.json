{
  "manifest_version": 3,
  "name": "Social Media Comment Scraper",
  "version": "1.0",
  "description": "Scrape and view social media comments in popup",

  "permissions": ["activeTab", "scripting", "tabs", "storage", "windows"],

  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.x.com/*",
    "https://*.instagram.com/*",
    "https://*.facebook.com/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*"
  ],

  "action": {
  "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.x.com/*",
        "https://*.instagram.com/*",
        "https://*.facebook.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
  "service_worker": "background.js"
  },

  "web_accessible_resources": [
    {
      "resources": [
      "popup.html",
      "libs/chart.js",
      "libs/wordcloud2.js"
    ],
      "matches": ["<all_urls>"]
    }
  ]
}
